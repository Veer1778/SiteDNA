# Everything below is optional. `pnpm dev`/`pnpm build`/`pnpm test` all work with zero env vars,
# using local filesystem adapters (.data/jobs, .data/assets) and skipping Vision AI.

# Enables Vision AI classification during the analyze pipeline (see @brandkit/vision). Without
# it, jobs go straight from "extracting" to "done" — voice/styleClassification are just [].
ANTHROPIC_API_KEY=
VISION_MODEL=claude-sonnet-5

# Job storage: set both to use Supabase instead of the local filesystem.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Asset storage: set all four to use Cloudflare R2 instead of the local filesystem.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
