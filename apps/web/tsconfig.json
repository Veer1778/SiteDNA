{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src", "app", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"],
  "references": [
    { "path": "../../packages/brand-engine" },
    { "path": "../../packages/crawler" },
    { "path": "../../packages/extractor" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/vision" }
  ]
}
